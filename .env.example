# Neon PostgreSQL (via Vercel Storage)
POSTGRES_URL=postgresql://user:password@host/neondb?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/neondb?sslmode=require
POSTGRES_DATABASE=neondb
POSTGRES_HOST=your-host.neon.tech
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=your-password

# Neon Auth
NEON_AUTH_BASE_URL=https://your-project.auth.neon.tech
NEON_AUTH_COOKIE_SECRET=your-cookie-secret-min-32-chars

# VAPID Keys for Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key
VAPID_EMAIL=your@email.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key

# Vercel Cron
CRON_SECRET=your-cron-secret
